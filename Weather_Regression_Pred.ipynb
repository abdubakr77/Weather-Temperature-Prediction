   "source": [
    "# --- Handling Outliers using IQR Method ---\n",
    "\n",
    "Q1 = np.percentile(df[\"Temperature\"], 25)\n",
    "Q3 = np.percentile(df[\"Temperature\"], 75)\n",
    "\n",
    "IQR = Q3 - Q1\n",
    "\n",
    "Lower = Q1 - 0.5 * IQR\n",
    "Upper = Q3 + 0.5 * IQR\n",
    "\n",
    "# Filtering the dataset\n"
    "mask = (df[\"Temperature\"] >= Lower) & (df[\"Temperature\"] <= Upper)\n",
    "\n",
    "df = df[mask]\n",
    "\n",
    "df\n"
   ]
  },
